# =============================================================
# Pairly / Luveloop Backend — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env to version control.
# =============================================================

# -----------------------------------------------
# ENVIRONMENT
# -----------------------------------------------
# Values: development | staging | production
ENVIRONMENT=development

# -----------------------------------------------
# DATABASE
# -----------------------------------------------
# MongoDB Atlas connection string (required)
MONGO_URL=mongodb+srv://<user>:<password>@cluster0.mongodb.net/truebond?retryWrites=true&w=majority

# -----------------------------------------------
# JWT AUTH
# -----------------------------------------------
# Strong random secret — generate with: openssl rand -hex 64
JWT_SECRET=change-me-to-a-strong-random-secret-at-least-64-chars

# JWT token expiry (seconds)
JWT_ACCESS_TOKEN_EXPIRE=3600
JWT_REFRESH_TOKEN_EXPIRE=604800

# -----------------------------------------------
# REDIS
# -----------------------------------------------
# Redis connection URL (used for PubSub, rate limiting, presence)
REDIS_URL=redis://localhost:6379

# -----------------------------------------------
# CORS / FRONTEND
# -----------------------------------------------
# Comma-separated list of allowed origins, or * for development
CORS_ORIGINS=http://localhost:5173,http://localhost:5000
FRONTEND_URL=http://localhost:5173

# -----------------------------------------------
# RATE LIMITING
# -----------------------------------------------
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_BAN_THRESHOLD=150
# Ban duration in seconds
RATE_LIMIT_BAN_DURATION=3600

# -----------------------------------------------
# PAYMENTS
# -----------------------------------------------
# Set PAYMENTS_MOCK_MODE=false and supply real keys in production
PAYMENTS_ENABLED=true
PAYMENTS_MOCK_MODE=true

# Stripe (international)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Razorpay (India)
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=...
RAZORPAY_WEBHOOK_SECRET=...

# -----------------------------------------------
# FIREBASE / FCM
# -----------------------------------------------
FIREBASE_API_KEY=
FIREBASE_PROJECT_ID=
# Path to service account JSON for FCM admin SDK
FIREBASE_SERVICE_ACCOUNT_PATH=

# -----------------------------------------------
# EMAIL (Password Reset / Notifications)
# -----------------------------------------------
EMAIL_PROVIDER=smtp
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@luveloop.app

# -----------------------------------------------
# STORAGE (Profile pictures / Message images)
# -----------------------------------------------
# Provider: local | s3 | r2 | supabase
STORAGE_PROVIDER=local
# For S3/R2:
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_S3_REGION=ap-south-1
# For Supabase:
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# -----------------------------------------------
# LOGGING
# -----------------------------------------------
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE_PATH=/var/log/pairly/app.log

# -----------------------------------------------
# FRAUD / RISK
# -----------------------------------------------
FRAUD_BLOCKLIST_FILE=
HIGH_VALUE_PURCHASE_CENTS=50000

# -----------------------------------------------
# DEVELOPER / TESTING
# -----------------------------------------------
# Dev account that gets 999999 coins — REMOVE IN PRODUCTION
DEV_USER_EMAIL=
